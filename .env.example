# The origin browsers will use to reach the stack. This gets baked into the
# frontend at container start, so it must match what you type in the address
# bar — restart the stack after changing it.
#
# Phase 1 (same-machine validation):
#   PUBLIC_ORIGIN=http://localhost:8080
# Phase 1b (LAN validation from another device, use the host's LAN IP):
#   PUBLIC_ORIGIN=http://192.168.1.50:8080
# Phase 3 (Tailscale, after `tailscale serve` is set up):
#   PUBLIC_ORIGIN=https://omen.your-tailnet.ts.net
PUBLIC_ORIGIN=http://localhost:8080

# Host port the nginx gateway is published on.
GATEWAY_PORT=8080
