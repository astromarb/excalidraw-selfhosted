# --- Tailscale sidecar -------------------------------------------------------
# Auth key used ONCE to join the stack to your tailnet as its own machine.
# Generate at https://login.tailscale.com/admin/settings/keys (a plain,
# non-reusable key is fine — identity persists in the tailscale-state volume).
TS_AUTHKEY=tskey-auth-REPLACE_ME

# Machine name the stack registers as.
TS_HOSTNAME=excalidraw

# Enable this only after tag:excalidraw has an authorized tag owner in the
# tailnet policy. Leave blank during the initial staged rollout.
TS_EXTRA_ARGS=

# Stable Tailscale addresses assigned to the persisted sidecar identity.
TS_IPV4=100.105.138.9
TS_IPV6=fd7a:115c:a1e0::9f37:8a0a

# --- Public names -------------------------------------------------------------
PUBLIC_ORIGIN=https://excalidraw.marvinlopezacevedo.com
LEGACY_ORIGIN=https://excalidraw.little-munsell.ts.net

# ACME CA used for the custom-domain certificate. Validate the deployment with
# Let's Encrypt staging first, then switch to the production URL.
ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_EMAIL=you@example.com

# Credentials returned by the ACME-DNS registration endpoint. Keep the actual
# file outside Git; the example file documents its shape.
ACMEDNS_CONFIG_FILE=./secrets/acmedns.json

# Host port for plain-HTTP access to the gateway (local testing only).
GATEWAY_PORT=8080
