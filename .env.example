# --- Tailscale sidecar -------------------------------------------------------
# Auth key used ONCE to join the stack to your tailnet as its own machine.
# Generate at https://login.tailscale.com/admin/settings/keys (a plain,
# non-reusable key is fine — identity persists in the tailscale-state volume).
TS_AUTHKEY=tskey-auth-REPLACE_ME

# Machine name the stack registers as; the app URL becomes
# https://<TS_HOSTNAME>.<tailnet>.ts.net
TS_HOSTNAME=excalidraw

# --- Frontend ----------------------------------------------------------------
# The origin browsers will use to reach the app. Baked into the frontend at
# container start — restart the stack after changing it. Must match the
# sidecar's MagicDNS name:
#   PUBLIC_ORIGIN=https://excalidraw.<your-tailnet>.ts.net
# For first-boot validation on the host itself you can temporarily use:
#   PUBLIC_ORIGIN=http://localhost:8080
PUBLIC_ORIGIN=https://excalidraw.your-tailnet.ts.net

# Host port for plain-HTTP access to the gateway (local testing only).
GATEWAY_PORT=8080
