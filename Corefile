.:53 {
    errors

    template IN A {
        match ^excalidraw[.]marvinlopezacevedo[.]com[.]$
        answer "{{ .Name }} 60 IN A {$TS_IPV4}"
    }

    template IN AAAA {
        match ^excalidraw[.]marvinlopezacevedo[.]com[.]$
        answer "{{ .Name }} 60 IN AAAA {$TS_IPV6}"
    }

    template ANY ANY {
        rcode REFUSED
    }
}
